NODE_ENV=development
PORT=3000

# Optional: LibreDWG CLI for raw .dwg → GeoJSON (network-workbench). If unset, backend also checks
# backend/Tools/LibreDWG/dwgread.exe and a few other paths — see backend/Tools/LibreDWG/README.md
# DWGREAD_PATH=C:\path\to\dwgread.exe

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=houji_p1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/houji_p1

# Public URL used in OTA/device callbacks. Set this to the externally reachable backend API base,
# for example https://api.example.com/api/v1 . If unset, firmware package URLs fall back to
# PUBLIC_WEB_BASE_URL + /api/v1.
# PUBLIC_API_BASE_URL=

# Optional: only set this when firmware binaries are also published to a CDN/static site and the
# device should download them directly by file name, for example https://cdn.example.com/ota .
# If unset, OTA package_url uses the backend artifact download API instead.
# FIRMWARE_PUBLIC_BINARY_BASE_URL=http://xupengpeng.top/bin

# MySQL dispatch mirror (optional). When enabled, exposes GET /api/v1/dispatch/team/:team/current and GET /api/v1/dispatch/task/:taskId
DISPATCH_DB_ENABLED=false
DISPATCH_DB_HOST=
DISPATCH_DB_PORT=3306
DISPATCH_DB_NAME=
DISPATCH_DB_USER=
DISPATCH_DB_PASSWORD=
# Writes: POST /api/v1/dispatch/task/:id/status | result-summary (requires DISPATCH_DB_WRITE_ENABLED=true)
DISPATCH_DB_WRITE_ENABLED=false
# Optional: if set, POST endpoints require header X-Dispatch-Write-Key matching this value
DISPATCH_WRITE_KEY=
