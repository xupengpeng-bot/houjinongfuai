{
  "name": "houjinongfuai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 backend scaffold for Houji agricultural irrigation platform.",
  "scripts": {
    "prestart:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3000",
    "prestart:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3000",
    "start": "nest start",
    "start:dev": "nest build && nest start --watch",
    "start:debug": "nest build && nest start --debug --watch",
    "port:kill:3000": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3000",
    "build": "nest build",
    "db:up": "docker compose -f docker-compose.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate.ps1",
    "db:migrate:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 -Reset",
    "db:seed": "npm run db:seed:reference",
    "db:seed:reference:sql": "powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1 -Group reference",
    "db:seed:reference": "npm run region-reference:import",
    "db:reset:reference-only": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-db-reference-only.ps1",
    "db:seed:baseline": "npm run db:seed:reference && powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1 -Group baseline",
    "db:seed:demo": "npm run db:seed:reference && powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1 -Group demo",
    "db:seed:test": "npm run db:seed:reference && powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1 -Group test",
    "db:seed:all": "npm run db:seed:reference && powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1 -Group all",
    "testdata:cleanup": "ts-node ./scripts/cleanup-test-data.ts",
    "region-reference:import": "ts-node ./scripts/import-region-reference.ts",
    "region-reference:verify": "ts-node ./scripts/verify-region-reference.ts",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:unit": "jest --config ./test/jest-unit.json --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "iconv-lite": "^0.7.2",
    "mysql2": "^3.14.0",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
