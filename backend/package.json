{
  "name": "houjinongfuai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 backend scaffold for Houji agricultural irrigation platform.",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "build": "nest build",
    "db:up": "docker compose -f docker-compose.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate.ps1",
    "db:migrate:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate.ps1 -Reset",
    "db:seed": "powershell -ExecutionPolicy Bypass -File ./scripts/seed.ps1",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
